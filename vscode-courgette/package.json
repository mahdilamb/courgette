{
  "name": "courgette",
  "displayName": "Courgette BDD",
  "description": "Gherkin syntax highlighting, test runner, param-level go-to-definition, and rainbow parameters for the Courgette BDD framework",
  "version": "0.1.0",
  "publisher": "mahdilamb",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Testing"
  ],
  "activationEvents": [
    "onLanguage:gherkin"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gherkin",
        "aliases": ["Gherkin", "Feature", "Cucumber"],
        "extensions": [".feature"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gherkin",
        "scopeName": "source.gherkin",
        "path": "./syntaxes/gherkin.tmLanguage.json"
      },
      {
        "scopeName": "gherkin.json.injection",
        "path": "./syntaxes/gherkin-json.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.json": "json" }
      },
      {
        "scopeName": "gherkin.python.injection",
        "path": "./syntaxes/gherkin-python.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.python": "python" }
      },
      {
        "scopeName": "gherkin.yaml.injection",
        "path": "./syntaxes/gherkin-yaml.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.yaml": "yaml" }
      },
      {
        "scopeName": "gherkin.xml.injection",
        "path": "./syntaxes/gherkin-xml.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.xml": "xml" }
      },
      {
        "scopeName": "gherkin.javascript.injection",
        "path": "./syntaxes/gherkin-javascript.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.javascript": "javascript" }
      },
      {
        "scopeName": "gherkin.sql.injection",
        "path": "./syntaxes/gherkin-sql.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.sql": "sql" }
      },
      {
        "scopeName": "gherkin.css.injection",
        "path": "./syntaxes/gherkin-css.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.css": "css" }
      },
      {
        "scopeName": "gherkin.markdown.injection",
        "path": "./syntaxes/gherkin-markdown.injection.json",
        "injectTo": ["source.gherkin"],
        "embeddedLanguages": { "meta.embedded.block.markdown": "markdown" }
      }
    ],
    "configurationDefaults": {
      "[gherkin]": {
        "editor.semanticHighlighting.enabled": false
      }
    },
    "configuration": {
      "title": "Courgette",
      "properties": {
        "courgette.steps.globs": {
          "type": "array",
          "default": [
            "**/step_*.py",
            "**/*_steps.py",
            "**/steps/**/*.py"
          ],
          "description": "Glob patterns to find step definition files"
        },
        "courgette.python.command": {
          "type": "string",
          "default": "",
          "description": "Command to run pytest (e.g. 'uv run', 'python3 -m', '/path/to/venv/bin/python -m'). Leave empty for auto-detection."
        },
        "courgette.steps.decorators": {
          "type": "array",
          "default": [
            "given",
            "when",
            "then",
            "step"
          ],
          "description": "Decorator names used for step definitions"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:watch": "vitest",
    "install-extension": "npm run compile && rm -rf \"${HOME}/.vscode/extensions/mahdilamb.courgette-0.1.0\" && mkdir -p \"${HOME}/.vscode/extensions/mahdilamb.courgette-0.1.0\" && cp package.json language-configuration.json \"${HOME}/.vscode/extensions/mahdilamb.courgette-0.1.0/\" && cp -r syntaxes out \"${HOME}/.vscode/extensions/mahdilamb.courgette-0.1.0/\"",
    "uninstall-extension": "rm -rf \"${HOME}/.vscode/extensions/mahdilamb.courgette-0.1.0\"",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
