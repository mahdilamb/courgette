{
  "scopeName": "gherkin.sql.injection",
  "injectionSelector": "L:source.gherkin",
  "patterns": [
    {
      "begin": "^\\s*(```|\"\"\")(sql)\\s*$",
      "end": "^\\s*(```|\"\"\")\\s*$",
      "name": "meta.embedded.block.sql",
      "contentName": "meta.embedded.block.sql",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.gherkin" },
        "2": { "name": "fenced_code.block.language.gherkin" }
      },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.gherkin" } },
      "patterns": [{ "include": "source.sql" }]
    }
  ]
}
