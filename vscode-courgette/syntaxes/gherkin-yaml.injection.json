{
  "scopeName": "gherkin.yaml.injection",
  "injectionSelector": "L:source.gherkin",
  "patterns": [
    {
      "begin": "^\\s*(```|\"\"\")(yaml|yml)\\s*$",
      "end": "^\\s*(```|\"\"\")\\s*$",
      "name": "meta.embedded.block.yaml",
      "contentName": "meta.embedded.block.yaml",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.gherkin" },
        "2": { "name": "fenced_code.block.language.gherkin" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.gherkin" }
      },
      "patterns": [
        { "include": "source.yaml" }
      ]
    }
  ]
}
